# App Settings
APP_NAME=My AI Hub API
DEBUG=false

# Security - CHANGE THESE IN PRODUCTION!
API_SECRET_KEY=your-secret-key-here
ADMIN_KEYS=admin-key-1,admin-key-2

# Hugging Face - Get token: https://huggingface.co/settings/tokens
HF_API_TOKEN=hf_your-token-here
HF_IMAGE_MODEL=stabilityai/stable-diffusion-2-1
HF_SONG_MODEL=facebook/musicgen-small

# Database
DATABASE_URL=sqlite:///./myai.db

# Usage Limits (per day for free users)
FREE_DAILY_IMAGE_GEN=10
FREE_DAILY_IMAGE_EDIT=5
FREE_DAILY_SONG_GEN=3

# File Storage
UPLOAD_FOLDER=./uploads
MAX_FILE_SIZE_MB=10

# Python
PYTHON_VERSION=3.11.0
